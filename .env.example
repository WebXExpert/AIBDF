# ---- AIBDF environment configuration ----
# Copy to .env (or .env.local) and fill with your real values. Never commit the real file.

# Required: Server port (Hostinger Passenger sets this automatically in production)
PORT=3000
NODE_ENV=production

# Required for Stripe donation checkout. Use a test key while testing.
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# Required for the AI Assistant (Gemini)
GEMINI_API_KEY=your_gemini_api_key

# ---- SMTP: required for Contact, Volunteer, and Patient Help forms ----
# Hostinger mailbox defaults:
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465 (SSL) or 587 (STARTTLS)
#   SMTP_USER is the full email address of a mailbox you own.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@aibdf.in
SMTP_PASS=your_mailbox_password
CONTACT_TO=info@aibdf.in
CONTACT_FROM=noreply@aibdf.in

# Optional
DISABLE_HMR=false
